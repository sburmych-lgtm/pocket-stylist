{
  "name": "pocket-stylist",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "prisma generate && tsc -p tsconfig.server.json && vite build",
    "start": "NODE_ENV=production sh -c 'npx prisma db push && exec node dist/server/server/index.js'",
    "lint": "eslint .",
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "prisma generate && tsc -b --noEmit",
    "preview": "vite preview",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:deploy": "npx prisma db push",
    "db:studio": "npx prisma studio",
    "db:push": "npx prisma db push"
  },
  "dependencies": {
    "@fal-ai/client": "^1.10.1",
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.90.21",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.1",
    "heic2any": "^0.0.4",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.577.0",
    "pg": "^8.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.18.1",
    "stripe": "^17.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.23.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.6",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  },
  "overrides": {
    "@hono/node-server": "1.19.13"
  }
}
