{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(tsc *)",
      "Bash(eslint *)",
      "Bash(prettier *)",
      "Bash(vitest *)",
      "Bash(prisma *)",
      "Bash(vite *)",
      "Bash(curl *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git stash*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git push)",
      "Bash(git push origin *)",
      "Bash(git remote *)",
      "Bash(git init*)",
      "Bash(git merge *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(echo *)",
      "Bash(wc *)",
      "Bash(rm *.tmp)",
      "Bash(rm -rf node_modules)",
      "Bash(rm -rf dist)",
      "Bash(rm -rf .next)",
      "Edit",
      "Read",
      "Write",
      "Agent",
      "Skill",
      "mcp__sequential-thinking__*",
      "mcp__context7__*",
      "mcp__playwright__*",
      "mcp__memory__*"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf .)",
      "Bash(rm -rf C:*)",
      "Bash(rm -rf G:*)",
      "Bash(del /s /q C:\\*)",
      "Bash(del /s /q G:\\*)",
      "Bash(format *)",
      "Bash(mkfs *)",
      "Bash(dd if=*)",
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f *)",
      "Bash(git push * -f)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -f *)",
      "Read(./**/secrets/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*.p12)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.npmrc)",
      "Read(~/.docker/config.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command // empty' | { read cmd; if echo \"$cmd\" | grep -qiE '(rm -rf /|rm -rf ~|rm -rf \\.|rm -rf C:|rm -rf G:|del /s /q|git reset --hard|git push.*--force|git push.*-f |dd if=|mkfs|format C|git clean -fd|git clean -f )'; then echo 'BLOCKED: Dangerous command rejected' >&2; exit 2; fi; }",
            "statusMessage": "Safety check..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read fp; if [ -n \"$fp\" ] && echo \"$fp\" | grep -qE '\\.(ts|tsx|js|jsx|json|css|md)$'; then npx prettier --write \"$fp\" 2>/dev/null || true; fi; }",
            "timeout": 10000,
            "statusMessage": "Auto-formatting..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"[System.Reflection.Assembly]::LoadWithPartialName('System.Windows.Forms'); [System.Windows.Forms.MessageBox]::Show('Claude Code needs attention', 'Pocket Stylist', 'OK', 'Information')\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"additionalContext\": \"Branch: '$(git branch --show-current 2>/dev/null || echo N/A)' | Last: '$(git log --oneline -1 2>/dev/null || echo N/A)'\"}'"
          }
        ]
      }
    ]
  }
}
