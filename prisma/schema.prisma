generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash       String?   @db.Text
  googleId           String?   @unique
  name               String?
  avatarUrl          String?
  googleAccessToken  String?   @db.Text
  googleRefreshToken String?   @db.Text
  googleDriveGrantedAt DateTime?
  colorSeason   String?
  colorPalette  Json?
  avoidColors   Json?
  genderMode    String    @default("neutral")
  // Geolocation for weather (Open-Meteo). Optional — falls back to mock weather.
  lat           Float?
  lon           Float?
  city          String?
  timezone      String?
  // Stylist persona: 'classic' | 'sassy' | 'manly' | 'kind'
  stylistPersona String   @default("classic")
  // GDPR / Terms acceptance timestamp. NULL for users created before this
  // column existed (grandfathered) so we don't lock them out.
  termsAcceptedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  wardrobeItems WardrobeItem[]
  outfits       Outfit[]
  outfitLogs    OutfitLog[]
  families      FamilyMember[]
  subscription  Subscription?
  outfitRenders OutfitRender[]
  feedback      Feedback[]

  @@map("users")
}

// Subscription state per user. Created on first login with 7-day trial.
// Stripe integration is gated behind STRIPE_SECRET_KEY — without it, all
// users get a permanent "trial" status (gracefully unlimited).
model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  status               String    @default("trialing") // trialing | active | past_due | canceled | none
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("subscriptions")
}

model WardrobeItem {
  id             String   @id @default(cuid())
  userId         String
  imageUrl       String
  thumbnailUrl   String?
  category       String
  subcategory    String?
  colorPrimary   String
  colorHex       String?
  pattern        String   @default("solid")
  fabric         String?
  formalityLevel Int      @default(3)
  season         String   @default("all")
  brand          String?
  price          Float?
  condition      String   @default("good")
  confidence     Float    @default(0)
  timesWorn      Int      @default(0)
  lastWornAt     DateTime?
  purchasedAt    DateTime?
  sharedWithFamily Boolean @default(false)
  tags           Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfitItems OutfitItem[]

  @@index([userId])
  @@index([category])
  @@index([userId, category])
  @@index([userId, createdAt])
  @@index([userId, sharedWithFamily])
  @@map("wardrobe_items")
}

model Outfit {
  id           String   @id @default(cuid())
  userId       String
  name         String
  stylingTip   String?
  confidence   Float    @default(0)
  liked        Boolean?
  contextHash  String?
  createdAt    DateTime @default(now())

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OutfitItem[]
  logs  OutfitLog[]

  @@index([userId])
  @@index([contextHash])
  @@map("outfits")
}

model OutfitItem {
  id             String @id @default(cuid())
  outfitId       String
  wardrobeItemId String

  outfit       Outfit       @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  wardrobeItem WardrobeItem @relation(fields: [wardrobeItemId], references: [id], onDelete: Cascade)

  @@unique([outfitId, wardrobeItemId])
  @@index([wardrobeItemId])
  @@map("outfit_items")
}

model OutfitLog {
  id       String   @id @default(cuid())
  userId   String
  outfitId String
  wornAt   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfit Outfit @relation(fields: [outfitId], references: [id], onDelete: Cascade)

  @@index([userId, wornAt])
  @@map("outfit_logs")
}

model Family {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  members FamilyMember[]

  @@map("families")
}

model FamilyMember {
  id       String @id @default(cuid())
  familyId String
  userId   String
  role     String @default("member")

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
  @@index([userId])
  @@map("family_members")
}

model OutfitRender {
  id              String   @id @default(cuid())
  userId          String
  modelImageUrl   String   @db.Text
  garmentImageUrl String   @db.Text
  resultImageUrl  String   @db.Text
  durationMs      Int
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("outfit_renders")
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  message   String   @db.Text
  userAgent String?  @db.Text
  source    String?  // page / context (e.g. "import", "wardrobe")
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId])
  @@map("feedback")
}

model GeminiUsage {
  id          String   @id @default(cuid())
  date        DateTime @default(now()) @db.Date
  requestType String
  tokenCount  Int      @default(0)
  count       Int      @default(1)

  @@unique([date, requestType])
  @@map("gemini_usage")
}
