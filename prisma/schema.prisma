generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash       String?   @db.Text
  googleId           String?   @unique
  name               String?
  avatarUrl          String?
  googleAccessToken  String?   @db.Text
  googleRefreshToken String?   @db.Text
  colorSeason   String?
  colorPalette  Json?
  avoidColors   Json?
  genderMode    String    @default("neutral")
  // GDPR / Terms acceptance timestamp. NULL for users created before this
  // column existed (grandfathered) so we don't lock them out.
  termsAcceptedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  wardrobeItems WardrobeItem[]
  outfits       Outfit[]
  outfitLogs    OutfitLog[]
  families      FamilyMember[]

  @@map("users")
}

model WardrobeItem {
  id             String   @id @default(cuid())
  userId         String
  imageUrl       String
  thumbnailUrl   String?
  category       String
  subcategory    String?
  colorPrimary   String
  colorHex       String?
  pattern        String   @default("solid")
  fabric         String?
  formalityLevel Int      @default(3)
  season         String   @default("all")
  brand          String?
  price          Float?
  condition      String   @default("good")
  confidence     Float    @default(0)
  timesWorn      Int      @default(0)
  lastWornAt     DateTime?
  purchasedAt    DateTime?
  tags           Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfitItems OutfitItem[]

  @@index([userId])
  @@index([category])
  @@map("wardrobe_items")
}

model Outfit {
  id           String   @id @default(cuid())
  userId       String
  name         String
  stylingTip   String?
  confidence   Float    @default(0)
  liked        Boolean?
  contextHash  String?
  createdAt    DateTime @default(now())

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OutfitItem[]
  logs  OutfitLog[]

  @@index([userId])
  @@index([contextHash])
  @@map("outfits")
}

model OutfitItem {
  id             String @id @default(cuid())
  outfitId       String
  wardrobeItemId String

  outfit       Outfit       @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  wardrobeItem WardrobeItem @relation(fields: [wardrobeItemId], references: [id], onDelete: Cascade)

  @@unique([outfitId, wardrobeItemId])
  @@map("outfit_items")
}

model OutfitLog {
  id       String   @id @default(cuid())
  userId   String
  outfitId String
  wornAt   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfit Outfit @relation(fields: [outfitId], references: [id], onDelete: Cascade)

  @@index([userId, wornAt])
  @@map("outfit_logs")
}

model Family {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  members FamilyMember[]

  @@map("families")
}

model FamilyMember {
  id       String @id @default(cuid())
  familyId String
  userId   String
  role     String @default("member")

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
  @@map("family_members")
}

model OutfitRender {
  id              String   @id @default(cuid())
  userId          String
  modelImageUrl   String   @db.Text
  garmentImageUrl String   @db.Text
  resultImageUrl  String   @db.Text
  durationMs      Int
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@map("outfit_renders")
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  message   String   @db.Text
  userAgent String?  @db.Text
  source    String?  // page / context (e.g. "import", "wardrobe")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("feedback")
}

model GeminiUsage {
  id          String   @id @default(cuid())
  date        DateTime @default(now()) @db.Date
  requestType String
  tokenCount  Int      @default(0)
  count       Int      @default(1)

  @@unique([date, requestType])
  @@map("gemini_usage")
}
